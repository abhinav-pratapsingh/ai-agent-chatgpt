PORT=6080
NODE_ENV=production
LOG_LEVEL=info
MONGODB_URI=
MONGODB_DB_NAME=ai_outreach_agent

ACTIVE_TIER=1
OUTREACH_MODE=combined
SMTP_PROVIDER=gmail

LEADS_PER_RUN=30
MIN_LEAD_SCORE=2
SLOW_WEBSITE_THRESHOLD=60
LOAD_TIME_THRESHOLD_MS=4000
COLLECTION_CONCURRENCY=3
EMAIL_EXTRACTION_CONCURRENCY=3
SPEED_ANALYSIS_CONCURRENCY=2
CAMPAIGN_SEARCH_LIMIT=25
GOOGLE_MAPS_SCROLL_ROUNDS=8
CAMPAIGN_POLL_CRON=*/15 * * * *
STATS_RESET_CRON=0 * * * *

PUPPETEER_HEADLESS=true
PUPPETEER_EXECUTABLE_PATH=
USER_AGENT=Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/124.0.0.0 Safari/537.36

OLLAMA_ENABLED=false
OLLAMA_BASE_URL=http://127.0.0.1:11434
OLLAMA_MODEL=llama3

FRONTEND_ORIGIN=http://localhost:4173
ADMIN_API_KEY=change-this-admin-key

GMAIL_USER=
GMAIL_APP_PASSWORD=

ZOHO_USER=
ZOHO_PASSWORD=

AMAZON_SES_HOST=email-smtp.us-east-1.amazonaws.com
AMAZON_SES_PORT=587
AMAZON_SES_USER=
AMAZON_SES_PASSWORD=

RESEND_SMTP_HOST=smtp.resend.com
RESEND_SMTP_PORT=587
RESEND_SMTP_USER=resend
RESEND_SMTP_PASSWORD=

SENDGRID_SMTP_HOST=smtp.sendgrid.net
SENDGRID_SMTP_PORT=587
SENDGRID_SMTP_USER=apikey
SENDGRID_SMTP_PASSWORD=

MAIL_FROM_NAME=
MAIL_FROM_EMAIL=
REPLY_TO_EMAIL=
TEST_MODE=true
TEST_RECIPIENT=
